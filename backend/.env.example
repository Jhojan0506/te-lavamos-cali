# ===== Configuración del servidor =====
PORT=3000
NODE_ENV=production

# Origen permitido para CORS (tu dominio del frontend)
# Ej: https://telavamoscali.com  (sin barra al final)
# Para varios dominios, sepáralos con coma: https://a.com,https://b.com
ALLOWED_ORIGIN=http://localhost:5500

# ===== Base de datos =====
DB_PATH=./data/clientes.db

# ===== WhatsApp =====
# Número del NEGOCIO al que llegan las solicitudes (formato internacional sin +)
# Ej: 573001112233
NUMERO_NEGOCIO=573000000000

# --- Opción A: Link sencillo wa.me (NO requiere API) ---
# Si no configuras WhatsApp Cloud API, el backend devolverá un link wa.me
# que el frontend abrirá automáticamente para enviar el mensaje.
WHATSAPP_MODE=link

# --- Opción B: WhatsApp Cloud API (envío automático real) ---
# Cambia WHATSAPP_MODE=cloud y completa estos valores desde
# https://developers.facebook.com/  (Meta for Developers)
# WHATSAPP_MODE=cloud
WHATSAPP_TOKEN=EAAG...tu_token_permanente
WHATSAPP_PHONE_ID=1234567890
# Nombre EXACTO de la plantilla aprobada en Meta (idioma es_CO o es)
WHATSAPP_TEMPLATE=nueva_solicitud
WHATSAPP_TEMPLATE_LANG=es_CO
